---
interface Props {
  ctaUrl: string
  ctaText: string
}

const { ctaUrl, ctaText } = Astro.props
---

<aside class="my-12 p-6 bg-accent/7 rounded-lg border border-accent/10 text-center">
  <p class="text-foreground/70 text-sm mb-4">
    30 minutes. No pitch. Just figuring out if there's a fit.
  </p>
  <a
    href={ctaUrl}
    target="_blank"
    rel="noopener noreferrer"
    class="inline-block px-6 py-2 bg-accent/15 text-foreground/90 rounded border border-accent/20 hover:bg-accent/25 hover:border-accent/30 transition-colors text-sm font-medium"
  >
    {ctaText}
  </a>
</aside>
