---
import { Image } from 'astro:assets'
import Layout from '~/layouts/Layout.astro'
import BookingForm from '~/components/BookingForm.astro'
import AiAssessmentWidget from '~/components/AiAssessmentWidget.astro'
import avatarImage from '~/content/avatar.jpg'
import type { AiCoachTranslations } from '~/i18n/ai-coach'

interface Props {
  t: AiCoachTranslations
}

const { t } = Astro.props
const appsScriptUrl = 'https://script.google.com/macros/s/AKfycbzpTiA0UIpMDHcMy3188VvDxhyJ_Xc0gbHlMmbLGR7LvdwDMY-viTkHi6ZWorub1MV-KA/exec'
---

<Layout title={t.title} description={t.description} lang={t.lang} hreflangAlternates={t.hreflangAlternates}>
  <article class="ai-coach max-w-full">

    <!-- ==================== HERO ==================== -->
    <header class="relative pt-16 pb-14">
      <div class="flex justify-end mb-8">
        <a href={t.otherLangUrl} class="text-xs text-foreground/40 hover:text-foreground/60 transition-colors">
          {t.otherLangLabel}
        </a>
      </div>

      <p class="text-xs uppercase tracking-[0.2em] text-accent/80 font-medium mb-5 hero-tagline">
        {t.heroTagline}
      </p>

      <h1 class="text-2xl sm:text-3xl font-medium text-foreground leading-tight mb-6 hero-heading">
        {t.heading}
      </h1>

      <p class="text-base text-foreground/70 max-w-xl mb-10 leading-relaxed hero-subtitle">
        {t.subtitle}
      </p>

      <div class="section-divider mt-14"></div>
    </header>

    <!-- ==================== ASSESSMENT ==================== -->
    <section class="pb-16">
      <div class="assessment-glow">
        <AiAssessmentWidget appsScriptUrl={appsScriptUrl} lang={t.lang} t={t.assessment} />
      </div>
    </section>

    <div class="section-divider"></div>

    <!-- ==================== HOW IT WORKS ==================== -->
    <section class="py-16">
      <h2 class="section-label mb-10">{t.howItWorksHeading}</h2>

      <div class="space-y-0">
        <!-- Step 1 -->
        <div class="flex gap-5 sm:gap-7 pb-8">
          <div class="flex flex-col items-center shrink-0">
            <div class="timeline-node">1</div>
            <div class="timeline-line flex-1 mt-2"></div>
          </div>
          <div class="pb-2 pt-1">
            <p class="text-sm font-medium text-foreground/85 mb-1.5">{t.meeting1Title}</p>
            <p class="text-sm text-foreground/55 leading-relaxed">{t.meeting1Description}</p>
          </div>
        </div>

        <!-- Step 2 -->
        <div class="flex gap-5 sm:gap-7 pb-8">
          <div class="flex flex-col items-center shrink-0">
            <div class="timeline-node">2</div>
            <div class="timeline-line flex-1 mt-2"></div>
          </div>
          <div class="pb-2 pt-1">
            <p class="text-sm font-medium text-foreground/85 mb-1.5">{t.meeting2Title}</p>
            <p class="text-sm text-foreground/55 leading-relaxed">{t.meeting2Description}</p>
          </div>
        </div>

        <!-- Step 3 -->
        <div class="flex gap-5 sm:gap-7">
          <div class="flex flex-col items-center shrink-0">
            <div class="timeline-node">3</div>
          </div>
          <div class="pt-1">
            <p class="text-sm font-medium text-foreground/85 mb-1.5">{t.meeting3Title}</p>
            <p class="text-sm text-foreground/55 leading-relaxed">{t.meeting3Description}</p>
          </div>
        </div>
      </div>

      <p class="text-sm text-foreground/35 mt-8 pl-[3.25rem] sm:pl-[3.75rem] leading-relaxed">{t.meetingsNote}</p>
    </section>

    <div class="section-divider"></div>

    <!-- ==================== OUTCOMES ==================== -->
    <section class="py-16">
      <h2 class="section-label mb-10">{t.walkAwayHeading}</h2>

      <div class="grid grid-cols-1 sm:grid-cols-2 gap-3">
        {t.walkAwayItems.map((item) => (
          <div class="outcome-card flex gap-3 p-4 rounded-lg border border-foreground/8 hover:border-foreground/15 transition-all duration-300">
            <span class="text-accent/60 shrink-0 mt-0.5 text-sm">&#10003;</span>
            <p class="text-sm text-foreground/70 leading-relaxed">{item}</p>
          </div>
        ))}
      </div>
    </section>

    <div class="section-divider"></div>

    <!-- ==================== SOCIAL PROOF ==================== -->
    <section class="py-16">
      <h2 class="section-label mb-10">{t.resultsHeading}</h2>

      <div class="grid grid-cols-1 sm:grid-cols-3 gap-5 mb-10">
        <!-- Featured metric -->
        <div class="sm:col-span-1 flex flex-col justify-center p-6 border border-accent/20 rounded-lg bg-accent/5 metric-card">
          <p class="text-3xl sm:text-4xl font-medium text-accent tracking-tight">{t.proofMetric}</p>
          <p class="text-sm text-foreground/45 mt-2 leading-relaxed">{t.proofMetricLabel}</p>
        </div>

        <!-- Case study -->
        <div class="sm:col-span-2 p-6 bg-foreground/[0.03] rounded-lg border border-foreground/8">
          <p class="text-sm font-medium text-foreground/80 mb-4">{t.resultCaseTitle}</p>
          <ul class="space-y-2.5 text-sm mb-5">
            {t.resultCaseItems.map((item) => (
              <li class="text-foreground/65 flex gap-2.5 items-start">
                <span class="text-accent/70 shrink-0 mt-0.5 text-xs">+</span>
                <span>{item}</span>
              </li>
            ))}
          </ul>
          <p class="text-sm text-accent/90 font-medium">{t.resultCaseHighlight}</p>
        </div>
      </div>

      <!-- Trust chips -->
      <div class="flex flex-wrap gap-2.5 justify-center">
        {t.proofCredentials.map((cred) => (
          <span class="text-sm text-foreground/45 px-3.5 py-1.5 border border-foreground/10 rounded-full tracking-wide">
            {cred}
          </span>
        ))}
      </div>
    </section>

    <div class="section-divider"></div>

    <!-- ==================== ABOUT ==================== -->
    <section class="py-16">
      <h2 class="section-label mb-8">{t.whyHeading}</h2>
      <div class="flex gap-5 sm:gap-6 items-start">
        <Image
          src={avatarImage}
          alt="Daniel Grahn"
          class="rounded-full border border-foreground/10 size-14 sm:size-16 aspect-square shrink-0"
          width={128}
          height={128}
        />
        <p class="text-sm text-foreground/65 leading-relaxed pt-1">{t.aboutBio}</p>
      </div>
    </section>

    <!-- ==================== MID-PAGE CTA ==================== -->
    <div class="relative py-14 text-center">
      <div class="section-divider absolute top-0 left-0 right-0"></div>

      <p class="text-lg font-medium text-foreground/90 mb-2">{t.midCtaHeading}</p>
      <p class="text-sm text-foreground/50 mb-8">{t.midCtaDescription}</p>
      <a href="#packages" class="inline-flex items-center gap-2 px-8 py-3 bg-accent/10 text-foreground/90 border border-accent/25 hover:bg-accent/20 hover:border-accent/40 transition-all duration-300 text-sm font-medium rounded">
        {t.midCtaButton}
        <svg class="w-3.5 h-3.5 opacity-50" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
          <path stroke-linecap="round" stroke-linejoin="round" d="M19 14l-7 7m0 0l-7-7m7 7V3" />
        </svg>
      </a>

      <div class="section-divider absolute bottom-0 left-0 right-0"></div>
    </div>

    <!-- ==================== FAQ ==================== -->
    <section class="py-16">
      <h2 class="section-label mb-10">{t.faqHeading}</h2>

      <div class="space-y-0">
        {t.faqItems.map((item) => (
          <details class="faq-item group border-b border-foreground/8">
            <summary class="flex items-center justify-between py-4 cursor-pointer text-sm text-foreground/80 hover:text-foreground/95 transition-colors">
              <span>{item.question}</span>
              <span class="faq-icon shrink-0 ml-4 text-foreground/30 text-xs transition-transform duration-200 group-open:rotate-45">+</span>
            </summary>
            <p class="text-sm text-foreground/55 pb-5 pr-8 leading-relaxed">{item.answer}</p>
          </details>
        ))}
      </div>
    </section>

    <div class="section-divider"></div>

    <!-- ==================== PRICING & BOOKING ==================== -->
    <section id="packages" class="py-16">
      <div class="text-center mb-10">
        <h2 class="text-base font-medium text-foreground/90 mb-2">{t.bookHeading}</h2>
        <p class="text-sm text-foreground/50">{t.bookSubtitle}</p>
      </div>

      <button type="button" data-package="intro" class="package-card w-full text-left p-5 bg-foreground/[0.03] rounded-lg border-2 border-dashed border-foreground/15 hover:border-foreground/25 transition-all duration-300 cursor-pointer mb-4 relative">
        <span class="absolute -top-2.5 right-4 px-2.5 py-0.5 bg-foreground/10 text-foreground/70 text-xs font-medium rounded-full border border-foreground/15">{t.packageIntroBadge}</span>
        <div class="flex flex-col sm:flex-row sm:items-center sm:gap-6">
          <div class="shrink-0">
            <p class="text-sm font-medium text-foreground/85 mb-1">{t.packageIntroTitle}</p>
            <p class="text-lg font-medium text-foreground/90">{t.packageIntroPrice} <span class="text-xs text-foreground/40 font-normal">{t.packageIntroPriceNote}</span></p>
          </div>
          <p class="text-sm text-foreground/55 mt-2 sm:mt-0 leading-relaxed">{t.packageIntroDescription}</p>
        </div>
      </button>

      <div class="grid grid-cols-1 md:grid-cols-2 gap-4 mb-8">
        <button type="button" data-package="single" class="package-card text-left p-6 bg-accent/5 rounded-lg border-2 border-accent/10 hover:border-accent/30 transition-all duration-300 cursor-pointer">
          <p class="text-sm font-medium text-foreground/85 mb-1">{t.packageSingleTitle}</p>
          <p class="text-xl font-medium text-foreground/90">{t.packageSinglePrice} <span class="text-xs text-foreground/40 font-normal">{t.packageSinglePriceNote}</span></p>
          <p class="text-sm text-foreground/55 mt-3 leading-relaxed">{t.packageSingleDescription}</p>
          <p class="text-sm text-foreground/40 mt-3">{t.packageSingleIncludes}</p>
        </button>
        <button type="button" data-package="bundle" class="package-card text-left p-6 bg-accent/5 rounded-lg border-2 border-accent/10 hover:border-accent/30 transition-all duration-300 cursor-pointer relative">
          <span class="absolute -top-2.5 right-4 px-2.5 py-0.5 bg-accent/20 text-foreground/80 text-xs font-medium rounded-full border border-accent/30">{t.packageBundleBadge}</span>
          <p class="text-sm font-medium text-foreground/85 mb-1">{t.packageBundleTitle}</p>
          <p class="text-xl font-medium text-foreground/90">{t.packageBundlePrice} <span class="text-xs text-foreground/40 font-normal">{t.packageBundlePriceNote}</span></p>
          <p class="text-sm text-accent/80 font-medium mt-1">{t.packageBundleSavings}</p>
          <p class="text-sm text-foreground/55 mt-3 leading-relaxed">{t.packageBundleDescription}</p>
          <p class="text-sm text-foreground/40 mt-3">{t.packageBundleIncludes}</p>
        </button>
      </div>

      <script>
        const defaultBorders = {
          intro: 'border-foreground/15',
          single: 'border-accent/10',
          bundle: 'border-accent/10',
        }
        const defaultBgs = {
          intro: 'bg-foreground/[0.03]',
          single: 'bg-accent/5',
          bundle: 'bg-accent/5',
        }

        function selectPagePackage(pkg) {
          document.querySelectorAll('.package-card').forEach(c => {
            c.classList.remove('border-accent/50', 'ring-1', 'ring-accent/30', 'bg-accent/10')
            c.classList.add(defaultBorders[c.dataset.package] || 'border-accent/10')
            c.classList.add(defaultBgs[c.dataset.package] || 'bg-accent/5')
          })
          const card = document.querySelector(`[data-package="${pkg}"]`)
          if (card) {
            card.classList.remove(defaultBorders[pkg] || 'border-accent/10')
            card.classList.remove(defaultBgs[pkg] || 'bg-accent/5')
            card.classList.add('border-accent/50', 'ring-1', 'ring-accent/30', 'bg-accent/10')
          }
          document.dispatchEvent(new CustomEvent('package-selected', { detail: pkg }))
        }

        document.querySelectorAll('.package-card').forEach(card => {
          card.addEventListener('click', () => selectPagePackage(card.dataset.package))
        })

        // Default to bundle selected
        selectPagePackage('bundle')
      </script>

      <BookingForm appsScriptUrl={appsScriptUrl} lang={t.lang} t={t.booking} />
    </section>

  </article>
</Layout>

<style>
  /* ===== Page-scoped styles for AI Coach landing page ===== */

  .ai-coach {
    --glow-color: var(--theme-accent);
  }

  /* Section labels — consistent heading treatment */
  .section-label {
    font-size: 0.75rem;
    text-transform: uppercase;
    letter-spacing: 0.18em;
    color: color-mix(in srgb, var(--theme-foreground) 45%, transparent);
    font-weight: 500;
  }

  /* Gradient dividers */
  .section-divider {
    height: 1px;
    background: linear-gradient(
      to right,
      transparent,
      color-mix(in srgb, var(--glow-color) 25%, transparent) 30%,
      color-mix(in srgb, var(--glow-color) 25%, transparent) 70%,
      transparent
    );
  }

  /* Hero entrance animations */
  .hero-tagline,
  .hero-heading,
  .hero-subtitle,
  .hero-stat {
    animation: hero-fade-up 0.6s ease-out both;
  }
  .hero-tagline { animation-delay: 0.05s; }
  .hero-heading { animation-delay: 0.12s; }
  .hero-subtitle { animation-delay: 0.2s; }
  .hero-stat { animation-delay: 0.3s; }

  @keyframes hero-fade-up {
    from {
      opacity: 0;
      transform: translateY(12px);
    }
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }

  /* Assessment glow wrapper */
  .assessment-glow {
    position: relative;
  }
  .assessment-glow::before {
    content: '';
    position: absolute;
    inset: -2px;
    border-radius: 0.6rem;
    background: radial-gradient(
      ellipse at 50% 0%,
      color-mix(in srgb, var(--glow-color) 12%, transparent),
      transparent 70%
    );
    z-index: -1;
    pointer-events: none;
  }

  /* Timeline nodes */
  .timeline-node {
    width: 2rem;
    height: 2rem;
    border-radius: 9999px;
    border: 1px solid color-mix(in srgb, var(--glow-color) 30%, transparent);
    background: color-mix(in srgb, var(--glow-color) 8%, transparent);
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 0.75rem;
    font-weight: 500;
    color: color-mix(in srgb, var(--theme-foreground) 65%, transparent);
    flex-shrink: 0;
  }

  .timeline-line {
    width: 1px;
    background: linear-gradient(
      to bottom,
      color-mix(in srgb, var(--glow-color) 20%, transparent),
      color-mix(in srgb, var(--glow-color) 5%, transparent)
    );
  }

  /* Metric card subtle pulse */
  .metric-card {
    position: relative;
    overflow: hidden;
  }
  .metric-card::after {
    content: '';
    position: absolute;
    inset: 0;
    border-radius: inherit;
    background: radial-gradient(
      circle at 30% 50%,
      color-mix(in srgb, var(--glow-color) 6%, transparent),
      transparent 60%
    );
    pointer-events: none;
  }

  /* Outcome card hover glow */
  .outcome-card {
    position: relative;
    transition: border-color 0.3s, background-color 0.3s;
  }
  .outcome-card:hover {
    background: color-mix(in srgb, var(--theme-foreground) 2%, transparent);
  }

  /* FAQ items */
  .faq-item summary {
    list-style: none;
  }
  .faq-item summary::-webkit-details-marker {
    display: none;
  }

  /* Scroll anchors */
  #assessment,
  #packages {
    scroll-margin-top: 2rem;
  }

  /* Reduce motion for users who prefer it */
  @media (prefers-reduced-motion: reduce) {
    .hero-tagline,
    .hero-heading,
    .hero-subtitle,
    .hero-stat {
      animation: none;
    }
  }
</style>
