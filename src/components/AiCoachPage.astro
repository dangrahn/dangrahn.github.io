---
import { Image } from 'astro:assets'
import Layout from '~/layouts/Layout.astro'
import BookingForm from '~/components/BookingForm.astro'
import AiAssessmentWidget from '~/components/AiAssessmentWidget.astro'
import avatarImage from '~/content/avatar.jpg'
import type { AiCoachTranslations } from '~/i18n/ai-coach'

interface Props {
  t: AiCoachTranslations
}

const { t } = Astro.props
const appsScriptUrl = 'https://script.google.com/macros/s/AKfycbzpTiA0UIpMDHcMy3188VvDxhyJ_Xc0gbHlMmbLGR7LvdwDMY-viTkHi6ZWorub1MV-KA/exec'
---

<Layout title={t.title} description={t.description} lang={t.lang} hreflangAlternates={t.hreflangAlternates}>
  <article class="max-w-full py-8">
    <div class="flex justify-end mb-2">
      <a href={t.otherLangUrl} class="text-xs text-foreground/50 hover:text-foreground/70 transition-colors">
        {t.otherLangLabel}
      </a>
    </div>

    <header class="mb-6">
      <h1 class="text-xl font-medium text-foreground mb-2">{t.heading}</h1>
      <p class="mt-6 mb-4 text-base text-foreground/90 font-medium">{t.subtitle}</p>
      <div class="flex justify-center mb-2">
        <Image
          src={avatarImage}
          alt="Daniel Grahn"
          class="rounded-full border border-foreground/10 size-20 aspect-square"
          width={160}
          height={160}
        />
      </div>
    </header>

    <AiAssessmentWidget appsScriptUrl={appsScriptUrl} lang={t.lang} t={t.assessment} />

    <!-- The gap -->
    <div class="py-4 mb-8">
      <h2 class="text-xs uppercase tracking-wider text-foreground/50 font-medium mb-3">{t.sectionHeading}</h2>
      <p class="text-sm text-foreground/80">{t.sectionDescription}</p>
    </div>

    <!-- How it works -->
    <section class="mb-12">
      <h2 class="text-xs uppercase tracking-wider text-foreground/50 font-medium mb-6">{t.howItWorksHeading}</h2>
      <div class="space-y-6">
        <div class="flex gap-4">
          <span class="text-foreground/30 text-sm font-medium shrink-0">01</span>
          <div>
            <p class="text-sm font-medium text-foreground/90">{t.meeting1Title}</p>
            <p class="text-sm text-foreground/60">{t.meeting1Description}</p>
          </div>
        </div>
        <div class="flex gap-4">
          <span class="text-foreground/30 text-sm font-medium shrink-0">02</span>
          <div>
            <p class="text-sm font-medium text-foreground/90">{t.meeting2Title}</p>
            <p class="text-sm text-foreground/60">{t.meeting2Description}</p>
          </div>
        </div>
        <div class="flex gap-4">
          <span class="text-foreground/30 text-sm font-medium shrink-0">03</span>
          <div>
            <p class="text-sm font-medium text-foreground/90">{t.meeting3Title}</p>
            <p class="text-sm text-foreground/60">{t.meeting3Description}</p>
          </div>
        </div>
      </div>
      <p class="text-sm text-foreground/50 mt-6">{t.meetingsNote}</p>
    </section>

    <!-- What you'll walk away with -->
    <section class="mb-12">
      <h2 class="text-xs uppercase tracking-wider text-foreground/50 font-medium mb-6">{t.walkAwayHeading}</h2>
      <ul class="space-y-2 text-sm">
        {t.walkAwayItems.map((item) => (
          <li class="text-foreground/80"><span class="text-foreground/30 mr-2">-</span>{item}</li>
        ))}
      </ul>
    </section>

    <!-- Real results -->
    <section class="mb-12">
      <h2 class="text-xs uppercase tracking-wider text-foreground/50 font-medium mb-6">{t.resultsHeading}</h2>
      <div class="space-y-4">
        <div class="p-4 bg-accent/7 rounded-lg border border-accent/10">
          <p class="text-sm font-medium text-foreground/90 mb-3">{t.resultCaseTitle}</p>
          <ul class="space-y-2 text-sm mb-4">
            {t.resultCaseItems.map((item) => (
              <li class="text-foreground/70"><span class="text-foreground/30 mr-2">-</span>{item}</li>
            ))}
          </ul>
          <p class="text-sm text-accent font-medium">{t.resultCaseHighlight}</p>
        </div>
      </div>
    </section>

    <!-- Pricing + Purchase -->
    <section class="mb-12">
      <h2 class="text-xs uppercase tracking-wider text-foreground/50 font-medium mb-6">{t.bookHeading}</h2>
      <p class="text-sm text-foreground/70 mb-6">{t.bookSubtitle}</p>
      <div class="grid grid-cols-1 md:grid-cols-2 gap-4 mb-8">
        <button type="button" data-package="single" class="package-card text-left p-5 bg-accent/7 rounded-lg border-2 border-accent/10 hover:border-accent/30 transition-colors cursor-pointer">
          <p class="text-sm font-medium text-foreground/90 mb-1">{t.packageSingleTitle}</p>
          <p class="text-lg font-medium text-foreground/90">{t.packageSinglePrice} <span class="text-xs text-foreground/50 font-normal">{t.packageSinglePriceNote}</span></p>
          <p class="text-sm text-foreground/60 mt-3">{t.packageSingleDescription}</p>
        </button>
        <button type="button" data-package="bundle" class="package-card text-left p-5 bg-accent/7 rounded-lg border-2 border-accent/25 hover:border-accent/30 transition-colors cursor-pointer relative">
          <span class="absolute -top-2.5 right-4 px-2 py-0.5 bg-accent/20 text-foreground/80 text-xs font-medium rounded-full border border-accent/30">{t.packageBundleBadge}</span>
          <p class="text-sm font-medium text-foreground/90 mb-1">{t.packageBundleTitle}</p>
          <p class="text-lg font-medium text-foreground/90">{t.packageBundlePrice} <span class="text-xs text-foreground/50 font-normal">{t.packageBundlePriceNote}</span></p>
          <p class="text-xs text-accent font-medium mt-1">{t.packageBundleSavings}</p>
          <p class="text-sm text-foreground/60 mt-3">{t.packageBundleDescription}</p>
        </button>
      </div>
      <script>
        function selectPagePackage(pkg) {
          document.querySelectorAll('.package-card').forEach(c => {
            c.classList.remove('border-accent/50', 'ring-1', 'ring-accent/30')
            c.classList.add(c.dataset.package === 'bundle' ? 'border-accent/25' : 'border-accent/10')
          })
          const card = document.querySelector(`[data-package="${pkg}"]`)
          if (card) {
            card.classList.remove('border-accent/10', 'border-accent/25')
            card.classList.add('border-accent/50', 'ring-1', 'ring-accent/30')
          }
          document.dispatchEvent(new CustomEvent('package-selected', { detail: pkg }))
        }

        document.querySelectorAll('.package-card').forEach(card => {
          card.addEventListener('click', () => selectPagePackage(card.dataset.package))
        })

        // Default to bundle selected
        selectPagePackage('bundle')
      </script>
      <BookingForm appsScriptUrl={appsScriptUrl} lang={t.lang} t={t.booking} />
    </section>

    <div class="flex justify-center mb-8">
      <Image
        src={avatarImage}
        alt="Daniel Grahn"
        class="rounded-full border border-foreground/10 size-20 aspect-square"
        width={160}
        height={160}
      />
    </div>

    <!-- Why -->
    <section class="mb-8">
      <h2 class="text-xs uppercase tracking-wider text-foreground/50 font-medium mb-6">{t.whyHeading}</h2>
      <p class="text-sm text-foreground/80">{t.whyParagraph1}</p>
      <p class="text-sm text-foreground/80 mt-3">{t.whyParagraph2}</p>
      <p class="text-sm text-foreground/80 mt-3">{t.whyParagraph3}</p>
    </section>
  </article>
</Layout>
