---
interface Props {
  checkoutUrl: string
  pricePerSeat?: number
}

const { checkoutUrl, pricePerSeat = 9900 } = Astro.props
---

<aside id="purchase" class="my-12 p-6 bg-accent/7 rounded-lg border border-accent/10">
  <div class="max-w-sm mx-auto">
    <label class="block text-foreground/70 text-sm mb-2" for="purchase-email">
      Your email
    </label>
    <input
      id="purchase-email"
      type="email"
      required
      placeholder="you@company.com"
      class="w-full px-3 py-2 bg-background border border-accent/20 rounded text-foreground text-sm placeholder:text-foreground/30 focus:outline-none focus:border-accent/40 mb-4"
    />

    <div class="flex items-center justify-between mb-4">
      <span class="text-foreground/70 text-sm">Seats</span>
      <div class="flex items-center gap-3">
        <button
          id="seat-decrement"
          type="button"
          class="w-8 h-8 flex items-center justify-center bg-accent/15 text-foreground/90 rounded border border-accent/20 hover:bg-accent/25 hover:border-accent/30 transition-colors text-sm font-medium"
        >
          -
        </button>
        <span id="seat-count" class="text-foreground/90 text-sm font-medium tabular-nums w-6 text-center">1</span>
        <button
          id="seat-increment"
          type="button"
          class="w-8 h-8 flex items-center justify-center bg-accent/15 text-foreground/90 rounded border border-accent/20 hover:bg-accent/25 hover:border-accent/30 transition-colors text-sm font-medium"
        >
          +
        </button>
      </div>
    </div>

    <div class="flex items-center justify-between mb-6">
      <span class="text-foreground/70 text-sm">Total</span>
      <span id="total-price" class="text-foreground/90 text-sm font-medium">
        {pricePerSeat.toLocaleString('sv-SE')} SEK
      </span>
    </div>

    <button
      id="purchase-button"
      type="button"
      class="w-full px-6 py-2 bg-accent/15 text-foreground/90 rounded border border-accent/20 hover:bg-accent/25 hover:border-accent/30 transition-colors text-sm font-medium"
    >
      Book coaching
    </button>
  </div>
</aside>

<script define:vars={{ checkoutUrl, pricePerSeat }}>
  const emailInput = document.getElementById('purchase-email')
  const seatCount = document.getElementById('seat-count')
  const totalPrice = document.getElementById('total-price')
  const decrementBtn = document.getElementById('seat-decrement')
  const incrementBtn = document.getElementById('seat-increment')
  const purchaseBtn = document.getElementById('purchase-button')

  let quantity = 1

  function updateDisplay() {
    seatCount.textContent = quantity
    const total = quantity * pricePerSeat
    totalPrice.textContent = total.toLocaleString('sv-SE') + ' SEK'
  }

  decrementBtn.addEventListener('click', () => {
    if (quantity > 1) {
      quantity--
      updateDisplay()
    }
  })

  incrementBtn.addEventListener('click', () => {
    quantity++
    updateDisplay()
  })

  purchaseBtn.addEventListener('click', () => {
    const email = emailInput.value.trim()
    if (!email) {
      emailInput.focus()
      return
    }

    const url = new URL(checkoutUrl)
    url.searchParams.set('checkout[email]', email)
    url.searchParams.set('checkout[quantity]', quantity)
    window.open(url.toString(), '_blank', 'noopener,noreferrer')
  })
</script>
